# Copy this file to .env and fill in your real values
# NEVER commit .env to git

# PostgreSQL
POSTGRES_USER=produser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=production_monitor

# Flask backend
DATABASE_URL=postgresql://produser:changeme@postgres:5432/production_monitor
SECRET_KEY=change-this-to-a-random-64-char-string
JWT_SECRET_KEY=change-this-to-a-different-random-64-char-string
JWT_ACCESS_TOKEN_EXPIRES_HOURS=24
FLASK_ENV=development

# Default admin password (used by 'flask seed' command)
ADMIN_DEFAULT_PASSWORD=admin123
